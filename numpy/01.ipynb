   "source": [
    "import numpy as np\n",
    "\n",
    "# Create an array\n",
    "a = np.array([1, 2, 3, 4])\n",
    "\n",
    "# Element-wise operations\n",
    "print(a * 2)      # [2 4 6 8]\n",
    "print(a + 10)     # [11 12 13 14]\n",
    "\n",
    "# Statistics\n",
    "print(a.mean())   # 2.5\n",
    "print(a.sum())    # 10"
   ]
